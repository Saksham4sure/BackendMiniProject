<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create a post</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body class="bg-[#FBF9F6] text-[#191919] min-h-screen flex flex-col justify-center py-12 sm:px-6 lg:px-8">

    <div class="sm:mx-auto sm:w-full sm:max-w-md text-center">
        <h2 class="mt-6 text-2xl font-medium tracking-tight text-[#191919]">
            Create a post
        </h2>
        <p class="mt-2 text-sm text-[#6B6B6B]">
            Enter your posts details below.
        </p>
    </div>

    <div class="mt-8 sm:mx-auto sm:w-full sm:max-w-md">
        <div class="bg-white py-8 px-4 border border-[#E8E3DA] rounded-xl sm:px-10">
            <form class="space-y-5" action="/post/create" method="POST">

                <div>
                    <label for="postName" class="block text-sm font-medium text-[#191919]">
                        Post Name
                    </label>
                    <div class="mt-1">
                        <input id="postName" name="postName" type="text" required autocomplete="name" placeholder="Node js"
                            class="appearance-none block w-full px-3 py-2.5 border border-[#E8E3DA] rounded-lg placeholder-[#A3A3A3] focus:outline-none focus:ring-1 focus:ring-[#D97706] focus:border-[#D97706] text-sm bg-[#FBF9F6]/50">
                    </div>
                </div>

                <div>
                    <label for="content" class="block text-sm font-medium text-[#191919]">
                        Content
                    </label>
                    <div class="mt-1">
                        <textarea id="content" name="content" type="" required autocomplete="name" placeholder="Whats on your mind?"
                            class="resize-none appearance-none block w-full px-3 py-2.5 h-30 border border-[#E8E3DA] rounded-lg placeholder-[#A3A3A3] focus:outline-none focus:ring-1 focus:ring-[#D97706] focus:border-[#D97706] text-sm bg-[#FBF9F6]/50"></textarea>
                    </div>
                </div>

                <div class="pt-2">
                    <input type="submit" value="Create post"
                        class="w-full flex justify-center py-2.5 px-4 border border-transparent rounded-lg text-sm font-medium text-white bg-[#D97706] hover:bg-[#B45309] focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[#D97706] transition-colors duration-200">
                    
                    </input>
                </div>
            </form>

            <div class="mt-6 text-center">
                <p class="text-sm text-[#6B6B6B]">
                    Dont wanna create post?
                    <a href="/profile"
                        class="font-medium text-[#D97706] hover:text-[#B45309] transition-colors duration-150">
                        Go to profile
                    </a>
                </p>
            </div>
        </div>
    </div>

</body>

</html>